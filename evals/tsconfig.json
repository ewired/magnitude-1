{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@magnitudedev/agent": ["../packages/agent/src"]
    }
  },
  "include": ["src/**/*.ts", "tests/**/*.ts"]
}
